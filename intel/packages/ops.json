{
  "package": {
    "name": "ops",
    "description": "Paperclip managing Paperclip + agentic marketing alpha",
    "version": 4,
    "company": "lemuriaos-ops",
    "owner_agent": "argus"
  },
  "output": {
    "raw": "raw/ops/",
    "drafts": "drafts/ops/"
  },
  "feed": {
    "categories": ["agentic-marketing", "agent-infrastructure"],
    "limit": 5,
    "sort": "newest"
  },
  "required_sources": [
    {
      "id": "gh-paperclip",
      "name": "Paperclip Releases",
      "type": "github-releases",
      "url": "https://github.com/paperclipai/paperclip/releases.atom",
      "category": "agentic-marketing",
      "pollIntervalMinutes": 360
    },
    {
      "id": "gh-claude-code",
      "name": "Claude Code Releases",
      "type": "github-releases",
      "url": "https://github.com/anthropics/claude-code/releases.atom",
      "category": "agent-infrastructure",
      "pollIntervalMinutes": 360
    }
  ],
  "transcripts": {
    "minDurationSec": 120,
    "maxRetryDays": 3
  }
}
